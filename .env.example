# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Slack - create a Slack app with the manifest in README.md
# Bot token starts with xoxb-
SLACK_BOT_TOKEN=xoxb-...
# App-level token for Socket Mode, starts with xapp-
SLACK_APP_TOKEN=xapp-...

# Channel ID (not name) - right-click channel in Slack -> View channel details -> copy ID at bottom
SLACK_CHANNEL_ID=C0123456789

# Scheduling
DAILY_POST_HOUR=8
DAILY_POST_MINUTE=0
TIMEZONE=America/New_York
